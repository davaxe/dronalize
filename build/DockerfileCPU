# syntax=docker/dockerfile:1.7

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# System deps (keep lean)
RUN apt-get update && apt-get install -y --no-install-recommends \
      python3 python3-pip python3-venv ca-certificates \
      libopenblas0 \
    && ln -sf /usr/bin/python3 /usr/bin/python \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install CPU PyTorch first (so it layers cleanly)
RUN python -m pip install --upgrade pip && \
    pip install torch==2.6.0 --index-url https://download.pytorch.org/whl/cpu

# Copy dependency descriptors first to leverage cache
COPY pyproject.toml README.md ./

# Install the rest from pyproject:
# - container: headless OpenCV, zarr
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -e .[container]

# Install `torch-cluster`
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install torch-cluster -f https://data.pyg.org/whl/torch-2.6.0+cpu.html


CMD ["python", "--version"]

